# ─── LLM ────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key_here

# ─── Vector Database ─────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ─── Collections ─────────────────────────────────────────────────────────────────
COLLECTION_PERSONAL=personal_memory
COLLECTION_NETWORK=network_knowledge
COLLECTION_VENDOR=vendor_news

# ─── Models ──────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
GROQ_MODEL=llama-3.3-70b-versatile
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ─── RAG Pipeline ────────────────────────────────────────────────────────────────
CHUNK_SIZE=600           # tokens per chunk
CHUNK_OVERLAP=120        # token overlap between chunks
HYBRID_ALPHA=0.7         # 0=pure BM25, 1=pure semantic
TOP_K_RETRIEVE=10        # candidates before reranking
TOP_K_RERANK=3           # final chunks sent to Groq

# ─── Scheduling ──────────────────────────────────────────────────────────────────
RSS_SYNC_INTERVAL_MINS=30
